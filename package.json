{
  "name": "berk-portfolio",
  "version": "1.0.0",
  "description": "Portfolio site for Berk Kocaborek, refactored for professional CI pipeline.",
  "scripts": {
    "lint:js": "eslint src/js/*.js",
    "lint:css": "stylelint src/css/*.css",
    "lint": "npm run lint:js && npm run lint:css",
    "build:css": "tailwindcss -i src/css/style.css -o public/dist/app.css --minify",
    "build:js": "mkdir -p public/dist && cp src/js/*.js public/dist/",
    "optimize:img": "node utils/image-optimizer.js",
    "build": "npm run build:css && npm run build:js && npm run optimize:img"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.1",
    "wrangler": "^4.68.1"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  }
}
